# このファイルを .env にコピーして値を埋めてください（.env は .gitignore 済み）。
# cp .env.example .env

# エンドポイントのベースURL。ログイン後のURLのドメインに合わせて選択。
#   通常:  https://atnd.ak4.jp/api/cooperation
#   AWJ系: https://atnd-awj.ak4.jp/api/cooperation
AK4_BASE_URL=https://atnd.ak4.jp/api/cooperation

# 企業ID（login_company_code）
AK4_COMPANY_ID=

# アクセストークン（マイページで発行。有効期限は「1ヶ月と1日」）
# 事前に従業員設定 > 利用機能設定 の「公開API利用可否」を「利用する」にする必要があります。
AK4_TOKEN=

# ===== カレンダー連動デーモン（sukesan）=====
# 退勤時刻をカレンダーの最終業務イベントに合わせる場合のみ設定。
# sukesan API のベースURL（ループバック限定）。
SUKESAN_BASE_URL=http://127.0.0.1:3000
# sukesan で発行した APIキー（64文字）。機密のため空のままにしないこと。
SUKESAN_API_KEY=
